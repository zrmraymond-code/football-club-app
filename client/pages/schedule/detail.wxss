.match-card-big { text-align: center; padding: 24px; }
.match-vs { display: flex; align-items: center; justify-content: center; gap: 20px; margin-bottom: 16px; }
.team-col { display: flex; flex-direction: column; align-items: center; gap: 8px; flex: 1; }
.logo-med { width: 64px; height: 64px; border-radius: 50%; background: #eee; }
.team-name-med { font-size: 16px; font-weight: 600; }
.vs-col { text-align: center; }
.score-big { font-size: 32px; font-weight: 700; color: #1a73e8; }
.vs-text { font-size: 20px; font-weight: 600; color: #1a73e8; }
.match-info { font-size: 14px; color: #555; display: flex; flex-direction: column; gap: 6px; }
