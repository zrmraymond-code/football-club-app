.team-header { text-align: center; padding: 24px; }
.logo-big { width: 72px; height: 72px; border-radius: 50%; background: #eee; }
.team-name-big { font-size: 20px; font-weight: 700; display: block; margin-top: 8px; }
.team-detail-info { font-size: 13px; color: #888; margin-top: 8px; display: flex; gap: 12px; justify-content: center; }

.player-header { display: flex; justify-content: space-between; margin-bottom: 12px; }
.player-count { font-size: 13px; color: #888; }

.player-item { display: flex; align-items: center; gap: 12px; padding: 8px 0; }
.player-avatar { width: 40px; height: 40px; border-radius: 50%; background: #eee; }
.player-info { flex: 1; }
.player-name { font-size: 15px; font-weight: 500; }
.player-position { font-size: 12px; color: #888; display: block; }
.player-number { font-size: 14px; font-weight: 600; color: #1a73e8; }
.section-title { font-size: 15px; font-weight: 600; }
.empty { text-align: center; color: #999; margin-top: 20px; font-size: 14px; }
