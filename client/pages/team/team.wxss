.team-item { display: flex; align-items: center; gap: 14px; }
.team-logo-lg { width: 56px; height: 56px; border-radius: 50%; background: #eee; }
.team-info-text { flex: 1; }
.team-name { font-size: 16px; font-weight: 600; display: block; }
.team-meta { font-size: 13px; color: #888; display: block; margin-top: 2px; }
.arrow { font-size: 22px; color: #ccc; }
.empty { text-align: center; color: #999; margin-top: 60px; font-size: 14px; }
