.filter-bar { display: flex; background: #fff; padding: 10px 16px; gap: 16px; }
.filter-item { font-size: 14px; color: #666; padding: 4px 0; }
.filter-item.active { color: #1a73e8; font-weight: 600; border-bottom: 2px solid #1a73e8; }
.act-top { display: flex; gap: 12px; }
.act-cover { width: 80px; height: 60px; border-radius: 8px; flex-shrink: 0; }
.act-info { flex: 1; display: flex; justify-content: space-between; }
.act-title { font-size: 15px; font-weight: 600; flex: 1; margin-right: 8px; }
.act-meta { font-size: 13px; color: #888; margin-top: 8px; display: flex; gap: 12px; flex-wrap: wrap; }
.empty { text-align: center; color: #999; margin-top: 60px; font-size: 14px; }
