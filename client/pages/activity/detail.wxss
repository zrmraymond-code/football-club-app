.detail-wrap { padding-bottom: 80px; }
.cover { width: 100%; height: 200px; }
.title { font-size: 18px; font-weight: 700; margin-bottom: 12px; display: block; }
.info-line { font-size: 14px; color: #555; margin-bottom: 6px; }
.section-label { font-size: 15px; font-weight: 600; display: block; margin-bottom: 8px; }
.desc { font-size: 14px; color: #555; line-height: 1.7; }
.ended-text { text-align: center; color: #999; font-size: 14px; }
.signup-btn {
  position: fixed; bottom: 20px; left: 16px; right: 16px; background: #1a73e8;
  color: #fff; border-radius: 10px; height: 46px; line-height: 46px; font-size: 16px; font-weight: 600;
}
.signup-btn.signed { background: #52c41a; }
.signup-btn[disabled] { background: #ccc; }
