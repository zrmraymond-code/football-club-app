page { background: #f5f7fa; }

.banner { height: 180px; }
.banner-img { width: 100%; height: 100%; }
.banner-placeholder {
  height: 100%; display: flex; align-items: center; justify-content: center;
  background: linear-gradient(135deg, #1a73e8, #0d47a1);
  color: #fff; font-size: 24px; font-weight: 600;
}

.nav-grid {
  display: flex; margin: 0 16px; background: #fff; border-radius: 12px;
  padding: 16px 0; box-shadow: 0 1px 4px rgba(0,0,0,.06);
}
.nav-item { flex: 1; display: flex; flex-direction: column; align-items: center; }
.nav-icon { font-size: 28px; margin-bottom: 4px; }
.nav-label { font-size: 13px; color: #333; }

.section-title {
  font-size: 16px; font-weight: 600; margin: 16px 16px 0; color: #333;
}

.activity-header { display: flex; justify-content: space-between; align-items: center; }
.activity-title { font-size: 15px; font-weight: 600; flex: 1; margin-right: 8px; }
.activity-meta { font-size: 13px; color: #888; margin-top: 8px; display: flex; gap: 12px; flex-wrap: wrap; }

.match-card { text-align: center; }
.match-teams { display: flex; align-items: center; justify-content: center; gap: 20px; margin: 12px 0; }
.team-info { display: flex; flex-direction: column; align-items: center; gap: 4px; font-size: 14px; }
.team-logo { width: 48px; height: 48px; border-radius: 50%; background: #eee; }
.vs { font-size: 18px; font-weight: 700; color: #1a73e8; }
.match-time { font-size: 13px; color: #888; }
