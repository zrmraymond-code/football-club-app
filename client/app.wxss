/* 全局样式 */
page {
  background: #f5f7fa;
  font-family: -apple-system, "PingFang SC", "Helvetica Neue", sans-serif;
}

.card {
  background: #fff;
  border-radius: 12px;
  margin: 12px 16px;
  padding: 16px;
  box-shadow: 0 1px 4px rgba(0,0,0,.06);
}

.btn-primary {
  background: #1a73e8;
  color: #fff;
  border-radius: 8px;
  padding: 10px 24px;
  font-size: 15px;
  text-align: center;
  border: none;
}

.btn-primary:active { opacity: .8; }

.input {
  width: 100%;
  padding: 10px 12px;
  border: 1px solid #ddd;
  border-radius: 8px;
  font-size: 15px;
  background: #fafafa;
  box-sizing: border-box;
}

.tag {
  display: inline-block;
  padding: 2px 10px;
  border-radius: 4px;
  font-size: 12px;
  color: #fff;
}

.tag-ongoing { background: #52c41a; }
.tag-ended   { background: #999; }
.tag-pending { background: #faad14; }
.tag-finished { background: #999; }
